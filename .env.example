# SAP S/4HANA Connection
SAP_BASE_URL=https://your-sap-host.com
SAP_CLIENT=100
SAP_LANGUAGE=EN
SAP_USER=your_user
SAP_PASSWORD=your_password

# SAP Organizational Defaults
SAP_SALES_ORG=1010
SAP_DISTRIBUTION_CHANNEL=10
SAP_DIVISION=00

# Mock Data Mode (set to "true" when SAP is unavailable)
USE_MOCK_DATA=false
